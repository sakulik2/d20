# d20-text-adventure configuration settings
ai:
  # Choose the provider from below (openai, deepseek, ollama)
  provider: "ollama"

  providers:
    openai:
      api_key: "YOUR_OPENAI_API_KEY_HERE"
      base_url: "https://api.openai.com/v1"
      model: "gpt-4-turbo"
    deepseek:
      api_key: "YOUR_DEEPSEEK_API_KEY_HERE"
      base_url: "https://api.deepseek.com/v1"
      model: "deepseek-chat"
    ollama:
      api_key: "ollama" # Not needed for local ollama, but kept for compatibility
      base_url: "http://localhost:11434/v1"
      model: "llama3"

game:
  # virtual (system generates random numbers) or manual (user inputs physical dice roll)
  dice_mode: "virtual"
  # Default ruleset to load from data/rulesets/
  ruleset: "fantasy.txt"
